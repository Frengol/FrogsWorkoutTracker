{
  "expo": {
    "name": "Frogs Workout Tracker",
    "slug": "frog-workout-tracker",
    "version": "0.1.4-beta",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frogworkouttracker",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "buildNumber": "1",
      "supportsTablet": true,
      "bundleIdentifier": "com.frogworkouttracker.app"
    },
    "android": {
      "versionCode": 5,
      "package": "com.frogworkouttracker.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F1C2C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "category": ["DEFAULT", "BROWSABLE"],
          "data": [
            { "scheme": "content", "mimeType": "text/csv" },
            { "scheme": "content", "mimeType": "application/csv" },
            { "scheme": "content", "mimeType": "text/comma-separated-values" },
            { "scheme": "content", "mimeType": "application/json" },
            { "scheme": "content", "mimeType": "text/json" },
            { "scheme": "content", "mimeType": "text/plain" },
            { "scheme": "content", "mimeType": "application/octet-stream" },
            { "scheme": "file", "mimeType": "text/csv", "pathPattern": ".*\\.csv" },
            { "scheme": "file", "mimeType": "application/csv", "pathPattern": ".*\\.csv" },
            { "scheme": "file", "mimeType": "text/comma-separated-values", "pathPattern": ".*\\.csv" },
            { "scheme": "file", "mimeType": "application/json", "pathPattern": ".*\\.json" },
            { "scheme": "file", "mimeType": "text/json", "pathPattern": ".*\\.json" },
            { "scheme": "file", "mimeType": "text/plain", "pathPattern": ".*\\.[cC][sS][vV]" },
            { "scheme": "file", "mimeType": "text/plain", "pathPattern": ".*\\.[jJ][sS][oO][nN]" },
            { "scheme": "file", "mimeType": "application/octet-stream", "pathPattern": ".*\\.[cC][sS][vV]" },
            { "scheme": "file", "mimeType": "application/octet-stream", "pathPattern": ".*\\.[jJ][sS][oO][nN]" }
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F1C2C",
          "dark": {
            "backgroundColor": "#0F1C2C"
          }
        }
      ],
      "expo-sqlite",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "O Frogs precisa acessar sua galeria para anexar fotos e videos aos treinos.",
          "cameraPermission": "O Frogs precisa acessar sua camera para registrar fotos do treino."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
