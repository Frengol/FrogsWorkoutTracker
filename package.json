{
  "name": "frog-workout-tracker",
  "main": "expo-router/entry",
  "version": "0.1.4-beta",
  "expo": {
    "install": {
      "exclude": [
        "@shopify/react-native-skia",
        "@types/jest",
        "jest-expo"
      ]
    }
  },
  "scripts": {
    "start": "expo start",
    "postinstall": "node ./scripts/patch-reanimated-gradle.js",
    "android": "expo run:android",
    "android:run": "expo run:android",
    "android:apk:debug": "cd android && ./gradlew --no-daemon --max-workers=2 -PreactNativeArchitectures=arm64-v8a,x86_64 assembleDebug",
    "android:apk:release": "cd android && rm -rf app/build/generated/assets/createBundleReleaseJsAndAssets app/build/generated/sourcemaps/react/release app/build/intermediates/assets/release app/build/intermediates/sourcemaps/react/release app/build/outputs/apk/release && NODE_ENV=production ./gradlew --no-daemon --max-workers=2 -PreactNativeArchitectures=arm64-v8a assembleRelease",
    "android:apk:diagnostics": "cd android && rm -rf app/build/generated/assets/createBundleReleaseJsAndAssets app/build/generated/sourcemaps/react/release app/build/intermediates/assets/release app/build/intermediates/sourcemaps/react/release app/build/outputs/apk/release && NODE_ENV=production EXPO_PUBLIC_FROGS_DIAGNOSTICS=1 ./gradlew --no-daemon --max-workers=2 -PreactNativeArchitectures=arm64-v8a assembleRelease",
    "android:aab:release": "cd android && rm -rf app/build/generated/assets/createBundleReleaseJsAndAssets app/build/generated/sourcemaps/react/release app/build/intermediates/assets/release app/build/intermediates/sourcemaps/react/release app/build/outputs/bundle/release && NODE_ENV=production ./gradlew --no-daemon --max-workers=2 -PreactNativeArchitectures=arm64-v8a bundleRelease",
    "ios": "expo run:ios",
    "ios:run": "expo run:ios",
    "web": "expo start --web",
    "native:sync": "npx expo prebuild",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand --no-cache",
    "test:coverage": "jest --runInBand --no-cache --coverage --coverageReporters=text-summary --coverageReporters=lcov",
    "validate:library": "jest --runInBand --no-cache tests/unit/library-content.test.ts"
  },
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo-google-fonts/sora": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@shopify/react-native-skia": "2.5.3",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.8",
    "expo-keep-awake": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.12",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.72.0",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "uuid": "^13.0.1",
    "victory-native": "^41.20.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.11",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "@expo/cli": {
      "ws": "8.20.1"
    },
    "@expo/metro-config": {
      "postcss": "8.5.10"
    },
    "@xmldom/xmldom": "^0.8.13",
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.13"
    },
    "minimatch@9.0.9": {
      "brace-expansion": "2.0.3"
    },
    "minimatch@10.2.4": {
      "brace-expansion": "5.0.6"
    },
    "node-forge": "^1.4.0",
    "xcode": {
      "uuid": "11.1.1"
    }
  },
  "license": "GPL-3.0-or-later",
  "private": true
}
